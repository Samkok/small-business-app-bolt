{
  "expo": {
    "name": "Business Manager Pro",
    "slug": "business-manager-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "businessmanager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "jsc",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.businessmanager.pro",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access for scanning",
        "NSPhotoLibraryUsageDescription": "Allow $(PRODUCT_NAME) to access your photo library to upload images",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save images to your photo library",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.businessmanager.pro",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router", 
      "expo-font", 
      "expo-web-browser",
      "expo-secure-store",
      "expo-camera"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}