{
  "expo": {
    "name": "BizManage",
    "slug": "business-manager-pro",
    "version": "2.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "businessmanager",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.businessmanager.pro",
      "usesPushNotifications": true,
      "infoPlist": {
        "NSCameraUsageDescription": "We use your camera so you can scan the barcode and take photos for your products, business profile, and user profile directly in the app.",
        "NSPhotoLibraryUsageDescription": "We use your photo library so you can upload photos for your products, business profile, and user profile. This helps you showcase your items and personalize your account.",
        "NSPhotoLibraryAddUsageDescription": "We save images to your photo library when you choose to export or download product photos or profile images.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesBackgroundNotificationActions": true
      }
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#2563eb",
      "iosDisplayInForeground": true,
      "androidMode": "default",
      "androidCollapsedTitle": "{{unread_count}} new notifications"
    },
    "android": {
      "package": "com.businessmanager.pro",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#2563eb",
          "sounds": [],
          "mode": "production"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
